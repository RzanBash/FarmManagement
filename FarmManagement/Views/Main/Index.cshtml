@{
    ViewData["Title"] = "Main";
}



    <link rel="stylesheet" href="~/css/Main.css" asp-append-version="true" />
    <!-- Swiper.js for slideshow -->
<link href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="~/css/Activities.css" asp-append-version="true" />



<section id="hero" >
    <div id="hero-carousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/img2.jpg" class="d-block w-100 hero-img" alt="Image 1">
                <div class="carousel-container">
                    <h2>Farming is the best solution of world's starvation</h2>
                    <p>Welcome to  Join us today and experience sustainable farming
                        .</p>
                </div>

            </div>

            <div class="carousel-item">
                <img src="~/images/farm.webp" class="d-block w-100 hero-img" alt="Image 2">
                <div class="carousel-container">
                    <h2>Farming as a Passione</h2>
                    <p>Cultivating passion, one crop at a time</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/img3 ..jpg" class="d-block w-100 hero-img" alt="Image 3">
                <div class="carousel-container">
                    <h2>Organic vegetables is good for health</h2>
                    <p>Fresh, organic, and healthy – the best for your body</p>
                </div>
            </div> 
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#hero-carousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#hero-carousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</section>




<section id="about-us" class="about-us-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 text-column text-start">
                <h2>Welcome To Green Haven</h2>
                <p class="lead">
                    At Green Haven, we are committed to providing fresh, organic products directly from our farm to your home. Our aim is to bring you closer to nature through sustainable farming practices and premium produce.
                </p>
                <p>
                    Our farm is not just about growing food—it’s about nurturing a lifestyle that connects you with the land, community, and environment. Experience the essence of nature with us.
                </p>
            </div>
            <div class="col-md-6 d-flex justify-content-center">
                <img src="~/Images/About.jpg" alt="Farm Image" class="img-fluid about-image">
            </div>
        </div>
    </div>
</section>

<section class="py-2" style="background-color: #e0e0e0;"></section>
<section class="section-beige text-center py-5" style="background-color: #f9f9f9;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="image-box mx-auto mb-4">
                    <img src="/images/cabinn.jpg" class="custom-img about-image" alt="Cabins">
                </div>
            </div>
            
          <div class="col-md-6 cottages-text">
          <h3 class="mb-3">Cabins</h3>
           <p class="mb-4">
               Enjoy a relaxing stay in our cozy farm cabins with beautiful views and a 
                 peaceful atmosphere,perfect for a restful retreat.
            </p>
             <a asp-controller="Main" asp-action="Cabins" class="btn btn-outline-success">View Cabins</a>
        </div>
    </div>
 </div>
</section>

<section class="py-2" style="background-color: #e0e0e0;"></section>
<section class="organic-products-section">
    <div class="container">
        <div class="row align-items-center">

<div class="col-md-6 text-content section-padding-left">
    <h3 class="mb-3">Our Organic Products</h3>
    <p class="mb-4">We offer a carefully curated selection of fresh organic products grown with care on our
        farm to ensure quality and health.</p>
    <a href="/Products" class="btn btn-outline-success">Shop Now</a>
</div>


            <div class="col-md-6">
                <div class="product-img-box">
                    <img src="/images/img.jpg" class="product-img" alt="Organic Products">
                </div>
            </div>
        </div>
    </div>
</section>


  <section class="py-2" style="background-color: #e0e0e0;"></section>

<section class="py-5 text-center activities-section" style="background-color: #f9f9f9;">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <div class="col-md-12 text-center">
                <h3 class="mb-3">Our Farm Activities</h3>
                <p class="mb-4">
                    Join in on fun farm activities such as animal feeding, fruit picking<br />and workshops for all ages,
                    creating memorable experiences for everyone.
                </p>

                <div class="swiper mySwiper">
                    <div class="swiper-wrapper">
                        <!-- Slide 1 -->
                        <div class="swiper-slide">
                            <img src="/images/to.jpg" alt="Planting Activity">
                        </div>

                        <!-- Slide 2 -->
                        <div class="swiper-slide">
                            <img src="/images/hors.jpg" alt="Horse Riding Activity">
                        </div>

                        <!-- Slide 3 -->
                        <div class="swiper-slide">
                            <img src="/images/cow.jpg" alt="Milking Cows Activity">
                        </div>

                        <!-- Slide 4 -->
                        <div class="swiper-slide">
                            <img src="/images/vi.jpg" alt="Fruit Picking Activity">
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="swiper-button-next"></div>
                    <div class="swiper-button-prev"></div>

                    <!-- Pagination Dots -->
                    <div class="swiper-pagination"></div>
                </div>
           </div>
        </div>
    </div>
</section>


<script>
    var swiper = new Swiper(".mySwiper", {
        loop: true,
        autoplay: {
            delay: 1000, // ثانية وحدة لكل صورة
            disableOnInteraction: false,
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
        },
    });
</script>





