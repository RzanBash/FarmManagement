@model IEnumerable<FarmManagement.Models.Cabin>

@{
    ViewData["Title"] = "Cabins";
}

<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Products, Cabins, and Bookings</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Main.css" asp-append-version="true" />

    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
</head>

<body>

    <div class="container" style="margin-top: 0; padding-top: 0;">
        <h2 class="custom-header">Available Cabins</h2>

        <div class="row justify-content-center">
            @foreach (var cabin in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card custom-cabin-card" style="border-radius: 15px;">
                        <img src="@cabin.ImageUrl" class="card-img-top" alt="Cabin Image"
                             style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                        <div class="card-body">
                            <h5 class="card-title">@cabin.Name</h5>
                            <p class="card-text">@cabin.Description</p>
                            <p><strong>Price:</strong> @cabin.PricePerNight.ToString("C") / night</p>
                            <p><strong>Capacity:</strong> @cabin.Capacity people</p>
                                 <p><strong>Available:</strong> @(cabin.IsAvailable == true ? "Yes" : "No")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="text-center my-5">
        <ul class="list-unstyled">
            <li class="nav-item">
                <a href="@Url.Action("CreateBooking", "Admin")" class="btn custom-contact-btn">
                    Book here
                </a>
            </li>
        </ul>
    </div>

</body>
</html>




                 
