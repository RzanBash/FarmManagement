@model FarmManagement.Models.Cabin

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Cabin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/create-styles.css" />
</head>
<body>

    <div class="container">
        <h2 class="text-center mb-5">Edit Cabin</h2>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="form-card">
                    <form asp-action="EditCabin" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="Id" value="@Model.Id" />

                        <!-- Cabin Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Cabin Name</label>
                            <input asp-for="Name" class="form-control" required pattern="^[A-Za-zأ-ي ]+$" title="Name must contain only letters" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" required pattern="^[A-Za-z0-9أ-ي ]+$" title="Only letters, numbers, and spaces allowed">@Model.Description</textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <!-- Price -->
                        <div class="mb-3">
                            <label asp-for="PricePerNight" class="form-label">Price per Night</label>
                            <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" required />
                            <span asp-validation-for="PricePerNight" class="text-danger"></span>
                        </div>

                        <!-- Capacity -->
                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label">Capacity</label>
                            <input asp-for="Capacity" class="form-control" type="number" required />
                            <span asp-validation-for="Capacity" class="text-danger"></span>
                        </div>

                        <!-- Availability -->
                        <div class="mb-3">
                            <label asp-for="IsAvailable" class="form-label">Availability</label>
                            <select asp-for="IsAvailable" class="form-control">
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                            <span asp-validation-for="IsAvailable" class="text-danger"></span>
                        </div>

                        <!-- Image -->
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label">Cabin Image</label>
                            <input type="file" asp-for="ImageUrl" class="form-control" />

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mt-2">
                                    <img src="@Url.Content(Model.ImageUrl)" alt="Cabin Image" class="img-thumbnail" width="150" />
                                </div>
                            }

                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <!-- Submit -->
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
