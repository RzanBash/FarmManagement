@model FarmManagement.Models.Product

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Product</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/create-styles.css" />
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
</head>
<body>

    <div class="container">
        <h2 class="text-center mb-5">Add New Product</h2>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="form-card">
                    <form asp-action="CreateProduct" method="post" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label for="Name" class="form-label">Product Name</label>
                            <input type="text" class="form-control" id="Name" name="Name" required pattern="^[A-Za-zأ-ي ]+$" title="Product name should only contain letters and spaces" />
                        </div>

                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" name="Description" required pattern="^[A-Za-z0-9أ-ي ]+$" title="Description should contain only letters, numbers, and spaces"></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="Price" class="form-label">Price</label>
                            <input type="number" class="form-control" id="Price" name="Price" step="0.01" required min="0" />
                        </div>

                        <div class="mb-4">
                            <label for="ImageUrl" class="form-label">Product Image (optional)</label>
                            <input type="file" class="form-control" id="ImageUrl" name="ImageUrl" />
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">Create Product</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
