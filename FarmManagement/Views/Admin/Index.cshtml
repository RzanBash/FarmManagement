@model FarmManagement.Models.AdminViewModel

<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Products, Cabins, and Bookings</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ملف التنسيقات العامة -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />

    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
</head>
<body>
    <div class="container py-3">
        
        <!-- عرض رسالة النجاح إذا كانت موجودة -->
      @if (TempData["SuccessMessage"] != null)
{
    <div id="successMessage" class="alert alert-success text-center">
        @TempData["SuccessMessage"]
    </div>

    <script>
        // بعد 3 ثواني (3000 ملي ثانية) سيتم إخفاء الرسالة
        setTimeout(function() {
            var message = document.getElementById('successMessage');
            if (message) {
                message.style.display = 'none';
            }
        }, 3000); // 3000 ملي ثانية = 3 ثواني
    </script>
}
</div>
        <!-- Products Section -->
        <h2 class="text-center text-dark mb-4">Product List</h2>
        <div class="card shadow-sm mb-4 fade-in">
            <div class="card-body">
                <table class="table table-sm table-bordered text-center align-middle fade-in">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th class="actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="text-center align-middle">@product.Name</td>
                                <td class="text-center align-middle">@product.Description</td>
                                <td class="text-center align-middle">@product.Price</td>
                                <td class="text-center align-middle">
                                      <a href="@Url.Action("DetailsProduct", "Admin", new { id = product.Id })" class="btn btn-sm btn-outline-primary">Details</a>
                                      <a href="@Url.Action("EditProduct", "Admin", new { id = product.Id })" class="btn btn-sm btn-outline-edit">Edit</a>

                                       <button type="button"
        class="btn btn-sm btn-outline-danger"
        data-bs-toggle="modal"
        data-bs-target="#deleteConfirmModal"
        data-action="@Url.Action("DeleteProduct", "Admin", new { id = product.Id })">
    Delete
</button>
                                   
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a href="@Url.Action("CreateProduct", "Admin")" class="btn btn-lg btn-block btn-outline-custom">Add New Product</a>
            </div>
        </div>

        <!-- Cabins Section -->
        <h2 class="text-center text-dark mb-4">Cabin List</h2>
        <div class="card shadow-sm mb-4 fade-in">
            <div class="card-body">
                <table class="table table-sm table-bordered text-center align-middle fade-in">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Capacity</th>
                            <th>Availability</th>
                            <th class="actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cabin in Model.Cabins)
                        {
                            <tr>
                                <td class="text-center align-middle">@cabin.Name</td>
                                <td class="text-center align-middle">@cabin.Description</td>
                                <td class="text-center align-middle">@cabin.PricePerNight</td>
                                <td class="text-center align-middle">@cabin.Capacity</td>
                                <td class="text-center align-middle">@(cabin.IsAvailable == true ? "Yes" : "No")</td>
                                <td class="text-center align-middle">
                                    <a href="@Url.Action("DetailsCabin", "Admin", new { id = cabin.Id })" class="btn btn-sm btn-outline-primary">Details</a>
                                    <a href="@Url.Action("EditCabin", "Admin", new { id = cabin.Id })" class="btn btn-sm btn-outline-edit">Edit</a>
                                   
<button type="button"
        class="btn btn-sm btn-outline-delete"
        data-bs-toggle="modal"
        data-bs-target="#deleteConfirmModal"
        data-action="@Url.Action("DeleteCabin", "Admin", new { id = cabin.Id })">
    Delete
</button>

                                  
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a href="@Url.Action("CreateCabin", "Admin")" class="btn btn-lg btn-block btn-outline-custom">Add New Cabin</a>
            </div>
        </div>

        <!-- Bookings Section -->
        <h2 class="text-center text-dark mb-4">Booking List</h2>
        <div class="card shadow-sm mb-4 fade-in">
            <div class="card-body">
                <table class="table table-sm table-bordered text-center align-middle fade-in">
                    <thead>
                        <tr>
                            <th>Customer Name</th>
                            <th>Phone Number</th>
                            <th>Check-in</th>
                            <th>Check-out</th>
                            <th>Status</th>
                            <th>Cabin</th>
                            <th class="actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td class="text-center align-middle">@booking.CustomerName</td>
                                <td class="text-center align-middle">@booking.PhoneNumber</td>
                                <td class="text-center align-middle">@booking.CheckInDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-center align-middle">@booking.CheckOutDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-center align-middle">@booking.Status</td>
                                <td class="text-center align-middle">@booking.Cabin.Name</td>
                                <td class="text-center align-middle">
                                    <a href="@Url.Action("DetailsBooking", "Admin", new { id = booking.Id })" class="btn btn-sm btn-outline-primary">Details</a>
                                    <a href="@Url.Action("EditBooking", "Admin", new { id = booking.Id })" class="btn btn-sm btn-outline-edit">Edit</a>
                                 
<button type="button"
        class="btn btn-sm btn-outline-delete"
        data-bs-toggle="modal"
        data-bs-target="#deleteConfirmModal"
        data-action="@Url.Action("DeleteBooking", "Admin", new { id = booking.Id })">
    Delete
</button>

                                  
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a href="@Url.Action("CreateBooking", "Admin")" class="btn btn-lg btn-block btn-outline-custom">Add New Booking</a>
            </div>
        </div>

   <!-- رسالة الحذف -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title" id="deleteConfirmLabel">Confirm Deletion 🗑️</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this item?
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    <button type="button" class="btn-outline-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn-danger">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // العثور على جميع الأزرار التي تفتح الـ modal
            var deleteButtons = document.querySelectorAll('[data-bs-toggle="modal"]');
            
            deleteButtons.forEach(function(button) {
                button.addEventListener("click", function() {
                    var actionUrl = this.getAttribute("data-action"); // الحصول على الـ URL من الخاصية data-action
                    var deleteForm = document.getElementById("deleteForm");
                    deleteForm.setAttribute("action", actionUrl); // تعيين الرابط في النموذج
                });
            });

            // البحث عن جميع العناصر التي تحتوي على الكلاس fade-in
            var fadeElements = document.querySelectorAll('.fade-in');
            fadeElements.forEach(function(element) {
                element.classList.add('visible'); // إضافة الكلاس visible لتطبيق التلاشي
            });
        });
    </script>

</body>

</html>
