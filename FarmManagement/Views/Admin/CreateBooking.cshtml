@model FarmManagement.Models.Booking

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Booking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/create-styles.css" />
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
</head>
<body>
    <div class="container ">
        <h2 class="text-center mb-5">Create Booking</h2>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="booking-card">
                    <form asp-action="CreateBooking" method="post">
                        <div class="mb-3">
                            <label for="CustomerName" class="form-label">Customer Name</label>
                            <input asp-for="CustomerName" class="form-control" pattern="^[A-Za-zأ-ي ]+$" required />
                        </div>
                        <div class="mb-3">
                            <label for="PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" pattern="\d+" required />
                        </div>
                        <div class="mb-3">
                            <label for="CheckInDate" class="form-label">Check-In Date</label>
                            <input asp-for="CheckInDate" class="form-control" type="date" required />
                        </div>
                        <div class="mb-3">
                            <label for="CheckOutDate" class="form-label">Check-Out Date</label>
                            <input asp-for="CheckOutDate" class="form-control" type="date" required />
                        </div>
                        <div class="mb-3">
                            <label for="CabinId" class="form-label">Select Cabin</label>
                            <select asp-for="CabinId" class="form-control" asp-items="@(new SelectList(ViewBag.Cabins, "Id", "Name"))" required>
                                <option value="">Choose a cabin</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label d-block">Status</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Pending" />
                                <label class="form-check-label">Pending</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Confirmed" />
                                <label class="form-check-label">Confirmed</label>
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">Create Booking</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
